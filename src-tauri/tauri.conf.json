{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoopThief",
  "version": "1.1.1",
  "identifier": "com.marekbarski.loopthief",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LoopThief",
        "width": 1600,
        "height": 1000,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Marek Barski",
    "category": "Music",
    "copyright": "Copyright © 2026 Marek Barski",
    "shortDescription": "MPC-style sampling instrument and groove workstation",
    "longDescription": "LoopThief is an MPC/SP-inspired sampler-sequencer workstation. Capture, chop, play, resample.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["lthief"],
        "name": "LoopThief Project",
        "description": "LoopThief Project File",
        "role": "Editor",
        "mimeType": "application/x-loopthief-project"
      }
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
