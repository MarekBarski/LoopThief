{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoopThief",
  "version": "0.1.0",
  "identifier": "com.marekbarski.loopthief",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LoopThief",
        "width": 1920,
        "height": 1080,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Music",
    "copyright": "© Marek Barski",
    "shortDescription": "LoopThief — MPC-style sampler-sequencer workstation",
    "longDescription": "LoopThief is a focused sampling instrument inspired by classic Akai MPC workflow: capture, chop, play, resample.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
