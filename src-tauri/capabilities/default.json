{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions LoopThief needs from Tauri's window + event + dialog + fs APIs",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:allow-destroy",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
